<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/rojo_umb">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SensorTempLuzUMB"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Universidad Manuela Beltrán"
        android:textSize="13sp"
        android:textColor="#CCFFFFFF"
        android:layout_marginBottom="56dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTemperatura"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:text="Sensor de Temperatura"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#33000000"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp"
        app:cornerRadius="8dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLuz"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:text="Sensor de Luz"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#33000000"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp"
        app:cornerRadius="8dp"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSalir"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:text="Salir"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#33000000"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp"
        app:cornerRadius="8dp"/>

</LinearLayout>